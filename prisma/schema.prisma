generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id             String   @id @default(cuid())
  title          String?
  description    String?
  pdfUrl         String?
  extractedText  String?  @db.Text
  analysis       String?  @db.Text
  objective      String?  @db.Text
  tone           String   @default("professional")
  language       String   @default("fr")
  enabledFormats String   @default("[]")
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contents FormatContent[]
  sessions ConsumptionSession[]
}

model FormatContent {
  id         String   @id @default(cuid())
  resourceId String
  format     String
  content    String   @db.Text
  version    Int      @default(1)
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, format])
}

model ConsumptionSession {
  id            String    @id @default(cuid())
  resourceId    String
  currentFormat String?
  completed     Boolean   @default(false)
  progress      String    @default("{}")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

// --- Interview IA ---

model InterviewResource {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  type                  String   @default("interview")  // "interview" | "pulse"
  theme                 String                          // "onboarding" | "satisfaction" | "retention" | custom
  tone                  String   @default("bienveillant")
  scopeIn               String?  @db.Text              // Zone verte — sujets à explorer
  scopeOut              String?  @db.Text              // Zone rouge — sujets hors périmètre
  anchorQuestions       String   @default("[]")        // JSON array of strings
  checkpointQuestions   String   @default("[]")        // JSON array of strings
  targetDurationMinutes Int      @default(15)
  maxQuestions          Int      @default(25)
  analysisTemplate      String?  @db.Text              // JSON — structure d'analyse configurable
  status                String   @default("draft")     // "draft" | "published"
  // Pulse-specific fields
  pulseQuestion         String?  @db.Text              // Question score NPS configurable
  pulseFrequency        String?                         // "weekly" | "biweekly" | "monthly"
  pulseMaxFollowUps     Int      @default(3)            // Max follow-up questions (1-3)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  sessions InterviewSession[]
}

model InterviewSession {
  id                  String    @id @default(cuid())
  interviewResourceId String
  participantName     String?
  status              String    @default("in_progress") // "in_progress" | "completed" | "abandoned"
  pulseScore          Int?                              // Score 1-10 for pulse sessions
  startedAt           DateTime  @default(now())
  completedAt         DateTime?

  interviewResource InterviewResource @relation(fields: [interviewResourceId], references: [id], onDelete: Cascade)
  messages          InterviewMessage[]
  analysis          InterviewAnalysis?
}

model InterviewMessage {
  id               String   @id @default(cuid())
  sessionId        String
  role             String                              // "user" | "assistant"
  content          String   @db.Text
  isAnchorQuestion Boolean  @default(false)
  isCheckpoint     Boolean  @default(false)
  createdAt        DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InterviewAnalysis {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  summary     String   @db.Text                        // JSON structuré selon analysisTemplate
  rawAnalysis String   @db.Text                        // Texte complet de l'analyse IA
  createdAt   DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// --- Agent IA ---

model Employee {
  id                  String    @id @default(cuid())
  firstName           String
  lastName            String
  email               String
  position            String
  department          String
  hireDate            DateTime
  managerId           String?
  status              String    @default("active")     // "active" | "onleave" | "departing"
  onboardingCompleted Boolean   @default(false)
  lastPulseScore      Float?
  avatarUrl           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  manager      Employee?    @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[]   @relation("EmployeeManager")
  suggestions  Suggestion[]
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  icon          String   @default("🤖")
  color         String   @default("#FF6058")

  category      String   @default("skill_rh")           // "skill_rh" | "skill_manager" | "custom"

  triggerType   String                                   // "event" | "scheduled"
  triggerLabel  String                                   // Label humain du déclencheur
  triggerConfig String   @default("{}") @db.Text         // JSON — paramètres du trigger

  infoDescription String? @db.Text                      // Ce que l'agent remonte

  actions       String   @default("[]") @db.Text         // JSON array d'actions

  isTemplate    Boolean  @default(false)
  templateId    String?                                  // ID du template source si créé depuis un template
  status        String   @default("draft")               // "draft" | "active" | "paused"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  suggestions   Suggestion[]
}

model Suggestion {
  id          String   @id @default(cuid())
  agentId     String
  employeeId  String?

  severity    String                                     // "urgent" | "attention" | "opportunity" | "optimization"
  category    String                                     // "onboarding" | "documents" | "engagement" | "management" | "formation" | "administratif"
  title       String
  summary     String   @db.Text

  context       String   @db.Text                        // JSON — infos contextuelles
  actionPlan    String   @db.Text                        // JSON — [{ id, label, detail? }]
  alternatives  String   @default("[]") @db.Text         // JSON — actions alternatives
  preview       String?  @db.Text                        // Markdown — prévisualisation

  status      String   @default("pending")               // "pending" | "accepted" | "customized" | "ignored"
  customizedAction String? @db.Text                      // JSON — action modifiée
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  actionLogs  ActionLog[]
}

model ActionLog {
  id            String   @id @default(cuid())
  suggestionId  String
  actionType    String                                   // "email" | "task" | "meeting"
  actionDetails String   @db.Text                        // JSON — détails de l'action simulée
  createdAt     DateTime @default(now())

  suggestion    Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
}
